@model Platform.WebClient.Models.DocumentsPageViewModel

@{
    ViewData["Title"] = "Documents";
}

<div class="container mt-4">
    <div class="d-flex align-items-center justify-content-between mb-3">
        <div>
            <h1 class="mb-1">@ViewData["Title"]</h1>
            <div class="text-muted">Signed in as @Model.UserName</div>
        </div>
        <a asp-action="CreateSample" class="btn btn-primary">Create sample document</a>
    </div>

    <div class="border rounded p-3 mb-4 bg-light">
        <div class="row g-3">
            <div class="col-md-4">
                <div class="small text-muted">User</div>
                <div class="fw-semibold">@Model.UserName</div>
            </div>
            <div class="col-md-4">
                <div class="small text-muted">Authentication</div>
                <div class="fw-semibold">@Model.AuthenticationType</div>
            </div>
            <div class="col-md-4">
                <div class="small text-muted">Roles</div>
                @if (Model.Roles.Count == 0)
                {
                    <span class="badge text-bg-secondary">none</span>
                }
                else
                {
                    foreach (var role in Model.Roles)
                    {
                        <span class="badge text-bg-primary me-1">@role</span>
                    }
                }
            </div>
        </div>
    </div>

    <h2 class="h5">Standard documents</h2>
    <table class="table table-striped">
        <thead>
            <tr>
                <th>ID</th>
                <th>Title</th>
                <th>Content</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var doc in Model.Documents)
            {
                <tr>
                    <td>@doc.Id</td>
                    <td>@doc.Title</td>
                    <td>@doc.Content</td>
                </tr>
            }
        </tbody>
    </table>

    <h2 class="h5 mt-4">Confidential documents</h2>
    @if (!string.IsNullOrWhiteSpace(Model.ConfidentialAccessMessage))
    {
        <div class="alert alert-warning">@Model.ConfidentialAccessMessage</div>
    }
    else
    {
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Title</th>
                    <th>Content</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var doc in Model.ConfidentialDocuments)
                {
                    <tr>
                        <td>@doc.Id</td>
                        <td>@doc.Title</td>
                        <td>@doc.Content</td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
