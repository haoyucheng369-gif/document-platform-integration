{
  "realm": "document-platform",
  "displayName": "DocumentPlatformIntegration",
  "enabled": true,
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "accessTokenLifespan": 300,
  "roles": {
    "realm": [
      {
        "name": "platform-user",
        "description": "User allowed to access platform web operations."
      },
      {
        "name": "platform-admin",
        "description": "Administrator allowed to execute privileged platform operations."
      },
      {
        "name": "platform-integration",
        "description": "Service role for machine-to-machine document integrations."
      }
    ]
  },
  "clients": [
    {
      "clientId": "platform-webclient",
      "name": "Platform WebClient",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "platform-webclient-secret",
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://localhost:5001/signin-oidc",
        "http://localhost:5167/signin-oidc",
        "https://localhost:7131/signin-oidc"
      ],
      "webOrigins": [
        "http://localhost:5001",
        "http://localhost:5167",
        "https://localhost:7131"
      ],
      "attributes": {
        "post.logout.redirect.uris": "http://localhost:5001/signout-callback-oidc##http://localhost:5167/signout-callback-oidc##https://localhost:7131/signout-callback-oidc"
      },
      "protocolMappers": [
        {
          "name": "platform-rest-api audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "platform-rest-api",
            "id.token.claim": "true",
            "access.token.claim": "true"
          }
        }
        ,
        {
          "name": "realm roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "claim.name": "roles",
            "jsonType.label": "String",
            "multivalued": "true",
            "access.token.claim": "true",
            "id.token.claim": "false",
            "userinfo.token.claim": "false"
          }
        }
      ]
    },
    {
      "clientId": "thirdparty-consumer",
      "name": "ThirdParty Consumer",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "thirdparty-consumer-secret",
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "protocolMappers": [
        {
          "name": "platform-rest-api audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "platform-rest-api",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
        ,
        {
          "name": "realm roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "claim.name": "roles",
            "jsonType.label": "String",
            "multivalued": "true",
            "access.token.claim": "true",
            "id.token.claim": "false",
            "userinfo.token.claim": "false"
          }
        }
      ]
    },
    {
      "clientId": "platform-rest-api",
      "name": "Platform REST API",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false
    }
  ],
  "users": [
    {
      "username": "service-account-thirdparty-consumer",
      "enabled": true,
      "emailVerified": true,
      "serviceAccountClientId": "thirdparty-consumer",
      "realmRoles": [
        "platform-integration"
      ]
    },
    {
      "username": "architect.user",
      "enabled": true,
      "email": "architect.user@example.local",
      "emailVerified": true,
      "requiredActions": [],
      "firstName": "Architect",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "password",
          "temporary": false
        }
      ],
      "realmRoles": [
        "platform-user"
      ]
    },
    {
      "username": "architect.admin",
      "enabled": true,
      "email": "architect.admin@example.local",
      "emailVerified": true,
      "requiredActions": [],
      "firstName": "Architect",
      "lastName": "Admin",
      "credentials": [
        {
          "type": "password",
          "value": "password",
          "temporary": false
        }
      ],
      "realmRoles": [
        "platform-user",
        "platform-admin"
      ]
    }
  ]
}
